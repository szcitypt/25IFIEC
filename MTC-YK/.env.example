# 复制本文件为 backend/.env 并按环境填写。
# Docker 全栈：`cd infra && docker compose up -d` 时，compose 会注入部分变量；
# 仍需在本文件提供密钥类项（如 SECRET_KEY、LLM_API_KEY）。变量名与 Pydantic Settings 字段对应（大写下划线）。

# --- 必需（生产/演示请改为强随机）---
SECRET_KEY=change-me-for-demo-only

# --- 数据库（compose 内已由环境块覆盖；本机直连容器 PG 时示例）---
# DATABASE_URL=postgresql+asyncpg://mtc:mtc_password@localhost:5432/mtc_db

# --- LLM（对话/故事书等）---
LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# --- 可选：向量/嵌入/Qdrant 与 compose 默认值通常一致 ---
# REDIS_URL=redis://localhost:6379/0
# QDRANT_URL=http://localhost:6333
# MINIO_ENDPOINT=localhost:9000
# MINIO_PUBLIC_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=mtc_access_key
# MINIO_SECRET_KEY=mtc_secret_key

# --- KouriChat（仅微信渠道需要时配置；见主 README）---
# KOURICHAT_DIR=/kourichat
